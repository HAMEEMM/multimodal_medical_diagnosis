# Data files  
# Ignore wav, mp3, and flac files
data/Medical*/recordings/**/*.wav
data/Medical*/recordings/**/*.mp3
data/Medical*/recordings/**/*.flac
data/Medical*/recordings/**/*.WAV

# Track important data files
!data/Medical\ Speech,\ Transcription,\ and\ Intent/overview-of-recordings.csv
# Track README files in data directories
!data/Medical\ Speech,\ Transcription,\ and\ Intent/README.md
processed/  
results/

