.DS_Store  
Thumbs.db

# Large document files - consider whether you want to track these or not
docs/*.pdf
docs/*.docx
docs/*.pptx
# To track specific files, uncomment the following lines:
# !docs/MahdiH\ Final\ Dissertation\ Manuscript.pdf